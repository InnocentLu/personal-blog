# ===================================
# Django 个人博客项目 .gitignore
# ===================================

# ===== Python =====
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ===== 虚拟环境 =====
venv/
env/
ENV/
env.bak/
venv.bak/
.venv/
virtualenv/

# ===== 环境变量与敏感配置 =====
.env
.env.local
.env.*.local
*.pem
*.key
credentials.json

# ===== Django 本地文件 =====
local_settings.py
db.sqlite3
db.sqlite3-journal
*.db
*.sqlite3

# ===== 媒体文件（本地用户上传） =====
media/
media/uploads/
media/avatars/
media/videos/
media/covers/
!media/.gitkeep

# ===== 静态文件（collectstatic 生成） =====
staticfiles/
static_collected/

# ===== 日志文件 =====
*.log
*.log.*
logs/
log/

# ===== IDE / 编辑器缓存 =====
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/
*.sublime-project
*.sublime-workspace
.atomignore
.atom/

# ===== 操作系统文件 =====
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# ===== 测试与覆盖率 =====
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.cache
.pytest_cache/
.mypy_cache/
dmypy.json
dmypy/

# ===== Git LFS =====
# Git LFS 钩子目录（自动生成）
.git/hooks/
