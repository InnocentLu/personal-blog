# ===================================
# .env 环境变量示例文件
# 使用时请复制为 .env 并填入实际值
# cp .env.example .env
# ===================================

# Django 安全密钥（生产环境请生成随机密钥）
DJANGO_SECRET_KEY=django-insecure-please-change-this-to-a-random-secret-key

# 调试模式（开发环境 True，生产环境 False）
DJANGO_DEBUG=True

# 允许访问的主机名（多个用逗号分隔，生产环境请填实际域名）
DJANGO_ALLOWED_HOSTS=*

# MySQL 数据库配置
DB_NAME=my_weblog
DB_USER=root
DB_PASSWORD=your-mysql-password-here
DB_HOST=localhost
DB_PORT=3306
